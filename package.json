{
  "name": "ai-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "start:all": "node scripts/start.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "fetch": "node scripts/engine.mjs once",
    "fetch:papers": "node scripts/fetch-papers.mjs",
    "fetch:all": "node scripts/engine.mjs once && node scripts/fetch-papers.mjs",
    "fetch:schedule": "node scripts/engine.mjs schedule 4",
    "fetch:watch": "node scripts/watch-wewe.mjs",
    "export": "node scripts/export-json.mjs",
    "postinstall": "node scripts/setup.mjs",
    "desktop:install": "cd desktop && npm install",
    "desktop:build": "cd desktop && npm run tauri build",
    "desktop:dev": "cd desktop && npm run tauri dev"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tailwindcss/typography": "^0.5.19",
    "cheerio": "^1.2.0",
    "next": "16.2.4",
    "node-cron": "^4.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rss-parser": "^3.13.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
